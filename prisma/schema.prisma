generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ConnectionStatus {
  ACTIVE
  EXPIRED
  ERROR
  MOCK
}

enum AccountStatus {
  ACTIVE
  LIMITED
  DISABLED
  BILLING_ISSUE
  UNKNOWN
}

enum ReadinessStatus {
  READY
  NEEDS_ATTENTION
  BLOCKED
  UNKNOWN
}

enum TokenStatus {
  VALID
  EXPIRED
  ERROR
  MOCK
  UNKNOWN
}

enum BillingStatus {
  OK
  ISSUE
  UNKNOWN
}

enum AuditResult {
  SUCCESS
  FAILED
}

enum Plan {
  free
  pro
  team
}

model User {
  id               String               @id @default(cuid())
  authUserId       String               @unique
  email            String               @unique
  name             String
  plan             Plan                 @default(free)
  planExpiresAt    DateTime?
  stripeCustomerId String?              @unique
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  metaConnections  MetaConnection[]
  adAccounts        MetaAdAccount[]
  accountPools      AccountPool[]
  poolItems         AccountPoolItem[]
  healthChecks      AccountHealthCheck[]
  auditLogs         AuditLog[]
  campaignTemplates CampaignTemplate[]
  creatives         Creative[]
  launchJobs        LaunchJob[]
  launchJobItems    LaunchJobItem[]
  headlineSets      HeadlineSet[]
}

model MetaConnection {
  id                   String           @id @default(cuid())
  userId               String
  name                 String
  accessTokenEncrypted String?
  status               ConnectionStatus @default(MOCK)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  adAccounts           MetaAdAccount[]

  @@index([userId])
}

model MetaAdAccount {
  id                String               @id @default(cuid())
  userId            String
  connectionId      String?
  externalId        String
  name              String
  currency          String               @default("USD")
  timezone          String               @default("UTC")
  status            AccountStatus        @default(UNKNOWN)
  readinessStatus   ReadinessStatus      @default(UNKNOWN)
  readinessScore    Int                  @default(0)
  billingStatus     BillingStatus        @default(UNKNOWN)
  tokenStatus       TokenStatus          @default(UNKNOWN)
  spendLimit        Decimal?             @db.Decimal(12, 2)
  notes             String?
  lastSyncAt        DateTime?
  lastHealthCheckAt DateTime?
  archived          Boolean              @default(false)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection        MetaConnection?      @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  pools             AccountPoolItem[]
  healthChecks      AccountHealthCheck[]
  launchJobItems    LaunchJobItem[]

  @@unique([userId, externalId])
  @@index([userId, status])
  @@index([userId, readinessStatus])
  @@index([userId, archived])
}

model AccountPool {
  id          String            @id @default(cuid())
  userId      String
  name        String
  description String?
  color       String            @default("#2563eb")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       AccountPoolItem[]

  @@unique([userId, name])
  @@index([userId])
}

model AccountPoolItem {
  id          String        @id @default(cuid())
  userId      String
  poolId      String
  adAccountId String
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pool        AccountPool   @relation(fields: [poolId], references: [id], onDelete: Cascade)
  adAccount   MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  @@unique([poolId, adAccountId])
  @@index([userId])
  @@index([adAccountId])
}

model AccountHealthCheck {
  id          String          @id @default(cuid())
  userId      String
  adAccountId String
  score       Int
  status      ReadinessStatus
  checksJson  Json
  createdAt   DateTime        @default(now())
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  adAccount   MetaAdAccount   @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([adAccountId, createdAt])
}

model AuditLog {
  id           String      @id @default(cuid())
  userId       String?
  action       String
  objectType   String
  objectId     String?
  oldValueJson Json?
  newValueJson Json?
  result       AuditResult @default(SUCCESS)
  errorMessage String?
  createdAt    DateTime    @default(now())
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([objectType, objectId])
}

model CampaignTemplate {
  id               String      @id @default(cuid())
  userId           String
  name             String
  objective        String
  buyingType       String      @default("AUCTION")
  campaignStatus   String      @default("PAUSED")
  dailyBudget      Decimal?    @db.Decimal(12, 2)
  bidStrategy      String      @default("LOWEST_COST_WITHOUT_CAP")
  optimizationGoal String      @default("LINK_CLICKS")
  billingEvent     String      @default("IMPRESSIONS")
  targetingJson    Json?
  adSetNameTpl     String      @default("{account} - AdSet")
  adNameTpl        String      @default("{account} - {creative}")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  launchJobs       LaunchJob[]

  @@index([userId])
}

model Creative {
  id             String   @id @default(cuid())
  userId         String
  name           String
  type           String   @default("IMAGE")
  zGroup         String?
  geo            String?
  mediaUrl       String?
  headline       String?
  primaryText    String?
  description    String?
  callToAction   String   @default("LEARN_MORE")
  destinationUrl String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, zGroup])
  @@index([userId, geo])
}

model HeadlineSet {
  id            String   @id @default(cuid())
  userId        String
  name          String
  source        String   @default("MANUAL")
  externalId    String?
  geo           String?
  headlinesJson Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, geo])
}

model LaunchJob {
  id                 String            @id @default(cuid())
  userId             String
  name               String
  campaignTemplateId String?
  status             String            @default("PENDING")
  totalAccounts      Int               @default(0)
  successCount       Int               @default(0)
  failedCount        Int               @default(0)
  configJson         Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  completedAt        DateTime?
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template           CampaignTemplate? @relation(fields: [campaignTemplateId], references: [id], onDelete: SetNull)
  items              LaunchJobItem[]

  @@index([userId, createdAt])
}

model LaunchJobItem {
  id           String        @id @default(cuid())
  launchJobId  String
  adAccountId  String
  userId       String
  status       String        @default("PENDING")
  errorMessage String?
  resultJson   Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  job          LaunchJob     @relation(fields: [launchJobId], references: [id], onDelete: Cascade)
  adAccount    MetaAdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([launchJobId])
  @@index([adAccountId])
}
