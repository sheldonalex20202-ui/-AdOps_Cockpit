# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon public key (Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — KEEP SECRET, server-side only (Settings → API)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# Transaction pooler URL (Settings → Database → Connection pooling)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection URL (Settings → Database → Connection string)
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ── JWT (Desktop auth tokens) ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe subscriptions ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-char-hex-encryption-key
